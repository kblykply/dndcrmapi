generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  OPEN
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  FOLLOW_UP
  CALL
  MEETING
  WHATSAPP
  EMAIL
  DOCS
  OTHER
}

enum Role {
  CALLCENTER
  MANAGER
  SALES
  ADMIN
}

enum LeadStatus {
  NEW
  WORKING
  SALES_READY
  MANAGER_REVIEW
  ASSIGNED
  WON
  LOST
  ARCHIVED
}

enum ActivityType {
  CALL
  NOTE
  MEETING
  WHATSAPP
  EMAIL
  STATUS_CHANGE
  ASSIGNMENT
}

enum CallOutcome {
  OPENED
  NO_ANSWER
  BUSY
  UNREACHABLE
  CALL_AGAIN
  INTERESTED
  NOT_INTERESTED
  QUALIFIED
  WON
  LOST
  WRONG_NUMBER
}

enum MetaPlatform {
  FB_MESSENGER
  IG
  LEAD_ADS
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  role         Role
  passwordHash String
  isActive     Boolean @default(true)

  avatarUrl String?

  managerId String?
  manager   User?   @relation("ManagerToReps", fields: [managerId], references: [id])
  reps      User[]  @relation("ManagerToReps")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  callcenterLeads Lead[] @relation("CallCenterOwner")
  managedLeads    Lead[] @relation("ManagerOwner")
  salesLeads      Lead[] @relation("SalesOwner")

  activities   LeadActivity[]     @relation("UserLeadActivities")
  stageChanges LeadStageHistory[] @relation("UserStageChanges")

  audits        AuditLog[]
  refreshTokens RefreshToken[]

  tasksCreated  Task[] @relation("TasksCreatedBy")
  tasksAssigned Task[] @relation("TasksAssignedTo")

  trustedDevices TrustedDevice[]
  loginOtps      LoginOtp[]

  agenciesManaged  Agency[] @relation("AgencyManager")
  agenciesAssigned Agency[] @relation("AgencySales")

  agencyNotesAuthored    AgencyNote[]    @relation("AgencyNoteAuthor")
  agencyMeetingsAuthored AgencyMeeting[] @relation("AgencyMeetingAuthor")
  agencyTasksCreated     AgencyTask[]    @relation("AgencyTaskCreator")
  agencyTasksAssigned    AgencyTask[]    @relation("AgencyTaskAssignee")

  ownedCustomers        Customer[]         @relation("CustomerOwner")
  presentationsCreated  Presentation[]     @relation("PresentationCreator")
  presentationsAssigned Presentation[]     @relation("PresentationSales")
  presentationNotes     PresentationNote[] @relation("PresentationNoteAuthor")

  @@index([role])
  @@index([isActive])
    crmTasksAssigned CrmTask[] @relation("CrmTaskAssignedTo")
  crmTasksCreated  CrmTask[] @relation("CrmTaskCreatedBy")
}

model Lead {
  id       String  @id @default(cuid())
  fullName String
  phone    String
  email    String?
  source   String?
  country  String?
  language String?
  notes    String?

  status LeadStatus @default(NEW)
  score  Int?

  avatarUrl String?

  // Meta-ready fields (for Messenger/IG profile photos later)
  metaPlatform MetaPlatform?
  metaPsid     String?
  metaLeadId   String?

  ownerCallCenterId String?
  ownerCallCenter   User?   @relation("CallCenterOwner", fields: [ownerCallCenterId], references: [id])

  assignedManagerId String?
  assignedManager   User?   @relation("ManagerOwner", fields: [assignedManagerId], references: [id])

  assignedSalesId String?
  assignedSales   User?   @relation("SalesOwner", fields: [assignedSalesId], references: [id])

  lastContactAt  DateTime?
  nextFollowUpAt DateTime?
  lastActivityAt DateTime?

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities   LeadActivity[]
  stageHistory LeadStageHistory[]

  // Opposite side of Task.lead
  tasks Task[] @relation("LeadTasks")

  @@unique([metaLeadId])
  @@index([status])
  @@index([nextFollowUpAt])
  @@index([assignedSalesId])
  @@index([assignedManagerId])
  @@index([ownerCallCenterId])
  @@index([phone])
  @@index([lastActivityAt])
  @@index([nextFollowUpAt, status])
  @@index([metaPsid])
  @@index([metaLeadId])
  @@index([metaPlatform])


  crmTasks CrmTask[]


  
}

model LeadActivity {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type    ActivityType
  summary String
  details String?

  callOutcome CallOutcome?

  createdById String
  createdBy   User   @relation("UserLeadActivities", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([callOutcome])
  @@index([type, createdAt])
}

model LeadStageHistory {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  fromStatus LeadStatus
  toStatus   LeadStatus

  changedById String
  changedBy   User   @relation("UserStageChanges", fields: [changedById], references: [id])

  changedAt DateTime @default(now())

  @@index([leadId, changedAt])
}

model AuditLog {
  id      String  @id @default(cuid())
  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id])

  action     String
  entityType String
  entityId   String
  metaJson   Json?
  ip         String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}

model RefreshToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime

  @@index([userId, expiresAt])
}

model Task {
  id String @id @default(cuid())

  title       String
  description String?
  type        TaskType     @default(FOLLOW_UP)
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(MEDIUM)

  dueAt      DateTime
  doneAt     DateTime?
  canceledAt DateTime?

  leadId String?
  lead   Lead?   @relation("LeadTasks", fields: [leadId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("TasksCreatedBy", fields: [createdById], references: [id])

  assignedToId String
  assignedTo   User   @relation("TasksAssignedTo", fields: [assignedToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId, status, dueAt])
  @@index([leadId, status, dueAt])
}

model TrustedDevice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceIdHash String
  tokenHash    String

  userAgent String?
  ip        String?

  lastSeenAt DateTime @default(now())
  expiresAt  DateTime

  createdAt DateTime @default(now())

  @@unique([userId, deviceIdHash])
  @@index([userId, expiresAt])
}

model LoginOtp {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  purpose   String // "DEVICE_TRUST"
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?

  deviceIdHash String

  createdAt DateTime @default(now())

  @@index([userId, purpose, expiresAt])
}

model Agency {
  id           String       @id @default(cuid())
  name         String
  contactName  String?
  phone        String?
  email        String?
  city         String?
  country      String?
  address      String?
  website      String?
  source       String?
  status       AgencyStatus @default(ACTIVE)
  notesSummary String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  managerId       String
  assignedSalesId String?

  manager       User  @relation("AgencyManager", fields: [managerId], references: [id])
  assignedSales User? @relation("AgencySales", fields: [assignedSalesId], references: [id])

  notes    AgencyNote[]
  meetings AgencyMeeting[]
  tasks    AgencyTask[]

  customers Customer[]

    crmTasks CrmTask[]


}

model AgencyNote {
  id          String   @id @default(cuid())
  agencyId    String
  createdById String
  note        String
  createdAt   DateTime @default(now())

  agency    Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdBy User   @relation("AgencyNoteAuthor", fields: [createdById], references: [id])
}

model AgencyMeeting {
  id          String   @id @default(cuid())
  agencyId    String
  createdById String
  title       String
  notes       String?
  meetingAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agency    Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdBy User   @relation("AgencyMeetingAuthor", fields: [createdById], references: [id])
}

model AgencyTask {
  id           String             @id @default(cuid())
  agencyId     String
  createdById  String
  assignedToId String?
  title        String
  description  String?
  dueAt        DateTime?
  status       AgencyTaskStatus   @default(TODO)
  priority     AgencyTaskPriority @default(MEDIUM)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  completedAt  DateTime?

  agency     Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdBy  User   @relation("AgencyTaskCreator", fields: [createdById], references: [id])
  assignedTo User?  @relation("AgencyTaskAssignee", fields: [assignedToId], references: [id])
}

enum AgencyStatus {
  ACTIVE
  PASSIVE
  PROSPECT
  DEALING
  CLOSED
}

enum AgencyTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum AgencyTaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Customer {
  id           String       @id @default(cuid())
  fullName     String
  companyName  String?
  phone        String?
  email        String?
  city         String?
  country      String?
  address      String?
  source       String?
  type         CustomerType @default(POTENTIAL)
  notesSummary String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id])

  ownerId String?
  owner   User?   @relation("CustomerOwner", fields: [ownerId], references: [id])

  presentations Presentation[]

    crmTasks CrmTask[]


}

model Presentation {
  id              String @id @default(cuid())
  customerId      String
  createdById     String
  assignedSalesId String

  title          String
  projectName    String?
  presentationAt DateTime
  location       String?
  status         PresentationStatus   @default(SCHEDULED)
  outcome        PresentationOutcome?
  notesSummary   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy     User     @relation("PresentationCreator", fields: [createdById], references: [id])
  assignedSales User     @relation("PresentationSales", fields: [assignedSalesId], references: [id])

  notes PresentationNote[]
}

model PresentationNote {
  id             String   @id @default(cuid())
  presentationId String
  createdById    String
  note           String
  createdAt      DateTime @default(now())

  presentation Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("PresentationNoteAuthor", fields: [createdById], references: [id])
}

enum CustomerType {
  POTENTIAL
  EXISTING
}

enum PresentationStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum PresentationOutcome {
  POSITIVE
  NEGATIVE
  FOLLOW_UP
  NO_DECISION
  WON
  LOST
}

model CrmTask {
  id          String   @id @default(cuid())
  title       String
  description String?

  status   CrmTaskStatus   @default(TODO)
  priority CrmTaskPriority @default(MEDIUM)

  dueAt       DateTime?
  completedAt DateTime?

  // 🔥 MULTI-RELATION SUPPORT
  leadId     String?
  agencyId   String?
  customerId String?

  assignedToId String?
  createdById  String

  // 🔥 RELATIONS
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agency   Agency?   @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  assignedTo User? @relation("CrmTaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User  @relation("CrmTaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([agencyId])
  @@index([customerId])
  @@index([leadId])
  @@index([dueAt])
}
enum CrmTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum CrmTaskPriority {
  LOW
  MEDIUM
  HIGH
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  OPEN
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  FOLLOW_UP
  CALL
  MEETING
  WHATSAPP
  EMAIL
  DOCS
  OTHER
}

enum Role {
  CALLCENTER
  MANAGER
  SALES
  ADMIN
  AFTERSALES
  ACCOUNTING
}

enum LeadStatus {
  NEW
  WORKING
  SALES_READY
  MANAGER_REVIEW
  ASSIGNED
  WON
  LOST
  ARCHIVED
}

enum ActivityType {
  CALL
  NOTE
  MEETING
  WHATSAPP
  EMAIL
  STATUS_CHANGE
  ASSIGNMENT
}

enum CallOutcome {
  OPENED
  NO_ANSWER
  BUSY
  UNREACHABLE
  CALL_AGAIN
  INTERESTED
  NOT_INTERESTED
  QUALIFIED
  WON
  LOST
  WRONG_NUMBER
}

enum MetaPlatform {
  FB_MESSENGER
  IG
  LEAD_ADS
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  role         Role
  passwordHash String
  isActive     Boolean @default(true)

  avatarUrl String?

  managerId String?
  manager   User?   @relation("ManagerToReps", fields: [managerId], references: [id])
  reps      User[]  @relation("ManagerToReps")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  callcenterLeads Lead[] @relation("CallCenterOwner")
  managedLeads    Lead[] @relation("ManagerOwner")
  salesLeads      Lead[] @relation("SalesOwner")

  activities   LeadActivity[]     @relation("UserLeadActivities")
  stageChanges LeadStageHistory[] @relation("UserStageChanges")

  audits        AuditLog[]
  refreshTokens RefreshToken[]
  refreshToken  String?

  tasksCreated  Task[] @relation("TasksCreatedBy")
  tasksAssigned Task[] @relation("TasksAssignedTo")

  trustedDevices TrustedDevice[]
  loginOtps      LoginOtp[]

  agenciesManaged  Agency[] @relation("AgencyManager")
  agenciesAssigned Agency[] @relation("AgencySales")

  agencyNotesAuthored    AgencyNote[]    @relation("AgencyNoteAuthor")
  agencyMeetingsAuthored AgencyMeeting[] @relation("AgencyMeetingAuthor")
  agencyTasksCreated     AgencyTask[]    @relation("AgencyTaskCreator")
  agencyTasksAssigned    AgencyTask[]    @relation("AgencyTaskAssignee")

  ownedCustomers         Customer[]                 @relation("CustomerOwner")
  presentationsCreated   Presentation[]             @relation("PresentationCreator")
  presentationsAssigned  Presentation[]             @relation("PresentationSales")
  presentationNotes      PresentationNote[]         @relation("PresentationNoteAuthor")
  crmTasksAssigned       CrmTask[]                  @relation("CrmTaskAssignedTo")
  crmTasksCreated        CrmTask[]                  @relation("CrmTaskCreatedBy")
  unitSelectionLogs      CustomerUnitSelectionLog[] @relation("UserUnitSelectionLogs")
  canceledUnitSelections CustomerUnitSelection[]    @relation("UnitCanceledBy")
  financeEntriesCreated  FinanceEntry[]             @relation("FinanceEntryCreatedBy")
  financeEntriesUpdated  FinanceEntry[]             @relation("FinanceEntryUpdatedBy")
  financeLogsAuthored    FinanceEntryLog[]          @relation("FinanceEntryLogAuthor")
  financeRatesCreated    FinanceExchangeRate[]      @relation("FinanceExchangeRateCreator")

  pdcaOwnedCases         PdcaCase[]      @relation("PdcaOwner")
  pdcaAssignedCases      PdcaCase[]      @relation("PdcaAssignedTo")
  pdcaCreatedCases       PdcaCase[]      @relation("PdcaCreatedBy")
  pdcaLogsAuthored       PdcaLog[]       @relation("PdcaLogAuthor")
  notifications          Notification[]
  agencyMeetingsAssigned AgencyMeeting[] @relation("AgencyMeetingSales")

  otherMeetingsCreated  OtherMeeting[] @relation("OtherMeetingCreator")
  otherMeetingsAssigned OtherMeeting[] @relation("OtherMeetingSales")

  @@index([role])
  @@index([isActive])
}

model Lead {
  id       String  @id @default(cuid())
  fullName String
  phone    String
  email    String?
  source   String?
  country  String?
  language String?
  notes    String?

  status LeadStatus @default(NEW)
  score  Int?

  avatarUrl String?

  // Meta-ready fields (for Messenger/IG profile photos later)
  metaPlatform MetaPlatform?
  metaPsid     String?
  metaLeadId   String?

  ownerCallCenterId String?
  ownerCallCenter   User?   @relation("CallCenterOwner", fields: [ownerCallCenterId], references: [id])

  assignedManagerId String?
  assignedManager   User?   @relation("ManagerOwner", fields: [assignedManagerId], references: [id])

  assignedSalesId String?
  assignedSales   User?   @relation("SalesOwner", fields: [assignedSalesId], references: [id])

  lastContactAt  DateTime?
  nextFollowUpAt DateTime?
  lastActivityAt DateTime?

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities   LeadActivity[]
  stageHistory LeadStageHistory[]

  // Opposite side of Task.lead
  tasks Task[] @relation("LeadTasks")

  crmTasks CrmTask[]

  @@unique([metaLeadId])
  @@index([status])
  @@index([nextFollowUpAt])
  @@index([assignedSalesId])
  @@index([assignedManagerId])
  @@index([ownerCallCenterId])
  @@index([phone])
  @@index([lastActivityAt])
  @@index([nextFollowUpAt, status])
  @@index([metaPsid])
  @@index([metaLeadId])
  @@index([metaPlatform])
}

model LeadActivity {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type    ActivityType
  summary String
  details String?

  callOutcome CallOutcome?

  createdById String
  createdBy   User   @relation("UserLeadActivities", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([callOutcome])
  @@index([type, createdAt])
}

model LeadStageHistory {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  fromStatus LeadStatus
  toStatus   LeadStatus

  changedById String
  changedBy   User   @relation("UserStageChanges", fields: [changedById], references: [id])

  changedAt DateTime @default(now())

  @@index([leadId, changedAt])
}

model AuditLog {
  id      String  @id @default(cuid())
  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id])

  action     String
  entityType String
  entityId   String
  metaJson   Json?
  ip         String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}

model RefreshToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime

  @@index([userId, expiresAt])
}

model Task {
  id String @id @default(cuid())

  title       String
  description String?
  type        TaskType      @default(FOLLOW_UP)
  status      CrmTaskStatus @default(TODO)
  priority    TaskPriority  @default(MEDIUM)

  dueAt      DateTime?
  doneAt     DateTime?
  canceledAt DateTime?

  leadId String?
  lead   Lead?   @relation("LeadTasks", fields: [leadId], references: [id], onDelete: SetNull)

  agencyId String?
  agency   Agency? @relation("AgencyTasks", fields: [agencyId], references: [id], onDelete: SetNull)

  customerId String?
  customer   Customer? @relation("CustomerTasks", fields: [customerId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("TasksCreatedBy", fields: [createdById], references: [id])

  assignedToId String
  assignedTo   User   @relation("TasksAssignedTo", fields: [assignedToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId, status, dueAt])
  @@index([leadId, status, dueAt])
  @@index([agencyId, status, dueAt])
  @@index([customerId, status, dueAt])
}

model TrustedDevice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceIdHash String
  tokenHash    String

  userAgent String?
  ip        String?

  lastSeenAt DateTime @default(now())
  expiresAt  DateTime

  createdAt DateTime @default(now())

  @@unique([userId, deviceIdHash])
  @@index([userId, expiresAt])
}

model LoginOtp {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  purpose   String // "DEVICE_TRUST"
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?

  deviceIdHash String

  createdAt DateTime @default(now())

  @@index([userId, purpose, expiresAt])
}

model Agency {
  id           String       @id @default(cuid())
  name         String
  contactName  String?
  phone        String?
  email        String?
  city         String?
  country      String?
  address      String?
  website      String?
  source       String?
  status       AgencyStatus @default(ACTIVE)
  notesSummary String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  managerId       String?
  assignedSalesId String?

  manager       User? @relation("AgencyManager", fields: [managerId], references: [id])
  assignedSales User? @relation("AgencySales", fields: [assignedSalesId], references: [id])

  notes         AgencyNote[]
  meetings      AgencyMeeting[]
  tasks         Task[]          @relation("AgencyTasks")
  customers     Customer[]
  crmTasks      CrmTask[]
  agencyTasks   AgencyTask[]
  presentations Presentation[]
}

model AgencyNote {
  id          String   @id @default(cuid())
  agencyId    String
  createdById String
  note        String
  createdAt   DateTime @default(now())

  agency    Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdBy User   @relation("AgencyNoteAuthor", fields: [createdById], references: [id])
}

model AgencyMeeting {
  id              String   @id @default(cuid())
  agencyId        String?
  createdById     String
  title           String
  notes           String?
  meetingAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  assignedSalesId String?
  customerId      String?

  status  MeetingStatus   @default(SCHEDULED)
  outcome MeetingOutcome?

  assignedSales User?     @relation("AgencyMeetingSales", fields: [assignedSalesId], references: [id])
  agency        Agency?   @relation(fields: [agencyId], references: [id])
  createdBy     User      @relation("AgencyMeetingAuthor", fields: [createdById], references: [id])
  customer      Customer? @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([agencyId])
  @@index([assignedSalesId])
  @@index([createdById])
  @@index([meetingAt])
  @@index([status])
}

model AgencyTask {
  id           String             @id @default(cuid())
  agencyId     String
  createdById  String
  assignedToId String?
  title        String
  description  String?
  dueAt        DateTime?
  status       AgencyTaskStatus   @default(TODO)
  priority     AgencyTaskPriority @default(MEDIUM)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  completedAt  DateTime?

  agency     Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdBy  User   @relation("AgencyTaskCreator", fields: [createdById], references: [id])
  assignedTo User?  @relation("AgencyTaskAssignee", fields: [assignedToId], references: [id])
}

enum AgencyStatus {
  ACTIVE
  PASSIVE
  PROSPECT
  DEALING
  CLOSED
}

enum AgencyTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum AgencyTaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Customer {
  id           String       @id @default(cuid())
  fullName     String
  companyName  String?
  phone        String?
  email        String?
  city         String?
  country      String?
  address      String?
  source       String?
  type         CustomerType @default(POTENTIAL)
  notesSummary String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id])

  ownerId String?
  owner   User?   @relation("CustomerOwner", fields: [ownerId], references: [id])

  presentations Presentation[]

  crmTasks CrmTask[]

  tasks Task[] @relation("CustomerTasks")

  language        String?
  nationality     String?
  identityNumber  String?
  oldCustomerCode String?
  oldCariCodes    String?
  gender          Gender?
  birthday        DateTime?
  job             String?
  project         ProjectType?
  idDocumentUrl   String?
  idDocumentName  String?

  unitSelections         CustomerUnitSelection[]
  previousUnitSelections CustomerUnitSelection[] @relation("UnitPreviousCustomer")
  documents              CustomerDocument[]
  agencyMeetings         AgencyMeeting[]
  financeEntries         FinanceEntry[]

  @@unique([oldCustomerCode])
  @@index([identityNumber])
}

model CustomerUnitSelection {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  previousCustomerId String?
  previousCustomer   Customer? @relation("UnitPreviousCustomer", fields: [previousCustomerId], references: [id], onDelete: SetNull)

  project    ProjectType
  unitNumber String

  deliveryStatus    UnitDeliveryStatus @default(NOT_READY)
  companyStatus     UnitCompanyStatus  @default(UNKNOWN)
  generalInfo       String?
  unitInfo          String?
  customerRequest   String?
  customerComplaint String?
  unitComplaint     String?

  isCanceled   Boolean   @default(false)
  canceledAt   DateTime?
  cancelReason String?
  canceledById String?
  canceledBy   User?     @relation("UnitCanceledBy", fields: [canceledById], references: [id], onDelete: SetNull)

  kdvStatus           String  @default("UNPAID")
  trafoStatus         String  @default("UNPAID")
  electricityProvider String  @default("UNKNOWN")
  waterAccessStatus   String  @default("UNKNOWN")
  rentalPackage       String  @default("NOT_INTERESTED")
  customFurniture     String?
  rentalStatus        String  @default("NOT_INTERESTED")

  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  logs           CustomerUnitSelectionLog[]
  financeEntries FinanceEntry[]
  financeSplits  FinanceEntrySplit[]

  @@unique([customerId, project, unitNumber])
  @@index([customerId])
  @@index([previousCustomerId])
  @@index([project])
  @@index([deliveryStatus])
  @@index([companyStatus])
  @@index([isCanceled])
  @@index([rentalStatus])
}

model CustomerUnitSelectionLog {
  id              String                @id @default(cuid())
  unitSelectionId String
  unitSelection   CustomerUnitSelection @relation(fields: [unitSelectionId], references: [id], onDelete: Cascade)

  section  String
  field    String
  oldValue String?
  newValue String?

  createdById String?
  createdBy   User?    @relation("UserUnitSelectionLogs", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([unitSelectionId, createdAt])
  @@index([createdById])
  @@index([section])
}

enum FinanceEntryKind {
  INCOME
  EXPENSE
}

enum FinancePaymentType {
  SALE_INSTALLMENT
  RENTAL_INCOME
  CREDIT_INSTALLMENT
  CHECK_PAYMENT
  REALTOR_COMMISSION
  SUBCONTRACTOR
  INVOICE
  OTHER
  TAX
  SALARY
}

enum FinancePaymentStatus {
  PLANNED
  PAID
  OVERDUE
  CANCELED
}

enum FinanceCurrency {
  GBP
  USD
  EUR
  TRY
}

enum FinanceSettlementMethod {
  CASH
  CHECK
  BARTER
  BANK_TRANSFER
  OTHER
}

model FinanceEntry {
  id String @id @default(cuid())

  kind        FinanceEntryKind
  paymentType FinancePaymentType
  status      FinancePaymentStatus @default(PLANNED)

  title             String
  description       String?
  vendorName        String?
  contractReference String?

  amount             Decimal         @db.Decimal(14, 2)
  currency           FinanceCurrency @default(GBP)
  exchangeRateToBase Decimal?        @db.Decimal(14, 6)
  baseCurrency       FinanceCurrency @default(GBP)

  originalDueDate      DateTime
  plannedDueDate       DateTime
  selectedDeferralDays Int?
  paidAt               DateTime?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  unitSelectionId String?
  unitSelection   CustomerUnitSelection? @relation(fields: [unitSelectionId], references: [id], onDelete: SetNull)

  project ProjectType?

  createdById String?
  createdBy   User?   @relation("FinanceEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   User?   @relation("FinanceEntryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dueOptions FinanceEntryDueOption[]
  splits     FinanceEntrySplit[]
  logs       FinanceEntryLog[]

  @@index([kind, plannedDueDate])
  @@index([status, plannedDueDate])
  @@index([paymentType])
  @@index([currency])
  @@index([customerId])
  @@index([unitSelectionId])
  @@index([project])
}

model FinanceEntryDueOption {
  id String @id @default(cuid())

  entryId String
  entry   FinanceEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  label            String
  daysFromOriginal Int
  dueDate          DateTime
  isSelected       Boolean  @default(false)

  createdAt DateTime @default(now())

  @@unique([entryId, daysFromOriginal])
  @@index([entryId])
  @@index([dueDate])
}

model FinanceEntrySplit {
  id String @id @default(cuid())

  entryId String
  entry   FinanceEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  method FinanceSettlementMethod
  ratio  Decimal                 @db.Decimal(6, 2)
  amount Decimal?                @db.Decimal(14, 2)
  note   String?

  unitSelectionId String?
  unitSelection   CustomerUnitSelection? @relation(fields: [unitSelectionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entryId])
  @@index([method])
  @@index([unitSelectionId])
}

model FinanceEntryLog {
  id String @id @default(cuid())

  entryId String
  entry   FinanceEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  action   String
  field    String?
  oldValue String?
  newValue String?

  createdById String?
  createdBy   User?    @relation("FinanceEntryLogAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([entryId, createdAt])
  @@index([createdById])
  @@index([action])
}

model FinanceExchangeRate {
  id String @id @default(cuid())

  currency      FinanceCurrency
  baseCurrency  FinanceCurrency @default(GBP)
  rateToBase    Decimal         @db.Decimal(14, 6)
  effectiveDate DateTime
  note          String?

  createdById String?
  createdBy   User?   @relation("FinanceExchangeRateCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([currency, baseCurrency, effectiveDate])
}

model CustomerDocument {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type        CustomerDocumentType
  fileName    String
  storagePath String
  mimeType    String?
  createdAt   DateTime             @default(now())

  @@index([customerId])
  @@index([customerId, type])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ProjectType {
  LA_JOYA
  LA_JOYA_PERLA
  LA_JOYA_PERLA_II
  LAGOON_VERDE
}

enum CustomerDocumentType {
  ID
  PASSPORT
  OTHER
}

enum UnitDeliveryStatus {
  NOT_READY
  READY_TO_DELIVER
  DELIVERED
}

enum UnitCompanyStatus {
  UNKNOWN
  DND
  OTHER
}

enum MeetingKind {
  AGENCY
  PRESENTATION
  OTHER
}

model Presentation {
  id              String  @id @default(cuid())
  customerId      String?
  createdById     String
  assignedSalesId String?
  agencyId        String?

  title          String
  projectName    String?
  presentationAt DateTime
  location       String?
  status         PresentationStatus   @default(SCHEDULED)
  outcome        PresentationOutcome?
  notesSummary   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])

  agency Agency? @relation(fields: [agencyId], references: [id])

  createdBy User @relation("PresentationCreator", fields: [createdById], references: [id])

  assignedSales User? @relation("PresentationSales", fields: [assignedSalesId], references: [id])

  notes PresentationNote[]

  @@index([agencyId])
}

model PresentationNote {
  id             String   @id @default(cuid())
  presentationId String
  createdById    String
  note           String
  createdAt      DateTime @default(now())

  presentation Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("PresentationNoteAuthor", fields: [createdById], references: [id])
}

enum CustomerType {
  POTENTIAL
  EXISTING
}

enum PresentationStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum MeetingOutcome {
  POSITIVE
  NEGATIVE
  FOLLOW_UP
  NO_DECISION
  WON
  LOST
}

enum PresentationOutcome {
  POSITIVE
  NEGATIVE
  FOLLOW_UP
  NO_DECISION
  WON
  LOST
}

model CrmTask {
  id          String  @id @default(cuid())
  title       String
  description String?

  status   CrmTaskStatus   @default(TODO)
  priority CrmTaskPriority @default(MEDIUM)

  dueAt       DateTime?
  completedAt DateTime?

  // 🔥 MULTI-RELATION SUPPORT
  leadId     String?
  agencyId   String?
  customerId String?

  assignedToId String?
  createdById  String

  // 🔥 RELATIONS
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agency   Agency?   @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  assignedTo User? @relation("CrmTaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User  @relation("CrmTaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([agencyId])
  @@index([customerId])
  @@index([leadId])
  @@index([dueAt])
}

enum CrmTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum CrmTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_DUE
  TASK_OVERDUE
  LEAD_ASSIGNED
  LEAD_STATUS_CHANGED
  LEAD_SENT_TO_MANAGER
  AGENCY_UPDATED
  CUSTOMER_UPDATED
  PRESENTATION_CREATED
  PRESENTATION_NOTE_ADDED
  SYSTEM
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String?
  isRead  Boolean          @default(false)

  entityType String?
  entityId   String?
  link       String?

  metaJson Json?

  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId, isRead, createdAt])
}

model OrgChartNode {
  id String @id @default(cuid())

  name  String // "Director", "Marketing Department" etc.
  type  String? // "DEPARTMENT", "ROLE", "GROUP" (optional for styling)
  color String? // for UI (like your yellow/green boxes)

  parentId String?
  parent   OrgChartNode?  @relation("OrgTree", fields: [parentId], references: [id], onDelete: Cascade)
  children OrgChartNode[] @relation("OrgTree")

  order Int @default(0) // for sorting inside same level

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model PdcaCase {
  id String @id @default(cuid())

  title          String
  problemSummary String
  department     String?
  issueCategory  PdcaIssueCategory?
  problemType    String?
  impactLevel    PdcaImpactLevel?
  priority       TaskPriority       @default(MEDIUM)

  phase  PdcaPhase  @default(PLAN)
  status PdcaStatus @default(OPEN)

  ownerId String?
  owner   User?   @relation("PdcaOwner", fields: [ownerId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("PdcaAssignedTo", fields: [assignedToId], references: [id])

  createdById String
  createdBy   User   @relation("PdcaCreatedBy", fields: [createdById], references: [id])

  rootCause        String?
  targetResult     String?
  actionPlan       String?
  doNotes          String?
  checkResult      String?
  correctiveAction String?
  preventiveAction String?
  finalDecision    String?

  dueAt    DateTime?
  closedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs PdcaLog[]

  @@index([phase])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([ownerId])
  @@index([createdById])
  @@index([dueAt])
}

model PdcaLog {
  id String @id @default(cuid())

  pdcaCaseId String
  pdcaCase   PdcaCase @relation(fields: [pdcaCaseId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("PdcaLogAuthor", fields: [createdById], references: [id])

  phase     PdcaPhase?
  note      String
  createdAt DateTime   @default(now())

  @@index([pdcaCaseId, createdAt])
  @@index([createdById])
}

model OtherMeeting {
  id              String  @id @default(cuid())
  createdById     String
  assignedSalesId String?

  title     String
  notes     String?
  meetingAt DateTime

  contactName String?
  companyName String?
  phone       String?
  email       String?

  status  MeetingStatus   @default(SCHEDULED)
  outcome MeetingOutcome?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy     User  @relation("OtherMeetingCreator", fields: [createdById], references: [id])
  assignedSales User? @relation("OtherMeetingSales", fields: [assignedSalesId], references: [id])

  @@index([assignedSalesId])
  @@index([createdById])
  @@index([meetingAt])
  @@index([status])
}

enum PdcaPhase {
  PLAN
  DO
  CHECK
  ACT
}

enum PdcaStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum PdcaImpactLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PdcaIssueCategory {
  SALES
  MARKETING
  OPERATIONS
  CUSTOMER_SERVICE
  FINANCE
  HR
  PROJECT
  OTHER
}
